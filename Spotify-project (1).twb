              <calculation class='tableau' formula='INT([Calculation_946600399729893379] / 0.10) * 0.10' />
            </column>
            <column aggregation='Sum' caption='Energy Intervals' datatype='real' name='[Calculation_982066251749638146]' role='dimension' type='ordinal'>
