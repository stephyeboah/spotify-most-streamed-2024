        <calculation class='tableau' formula='IF { FIXED [Calculation_982066251749638146], [Calculation_982066251750973443] : AVG([Popularity]) } &lt;= 71 THEN &quot;Low&quot;&#13;&#10;ELSEIF { FIXED [Calculation_982066251749638146], [Calculation_982066251750973443] : AVG([Popularity]) } &lt;= 78 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
