            </column>
            <column datatype='integer' name='[Popularity]' role='measure' type='quantitative' />
            <column aggregation='CountD' caption='Danceability' datatype='string' name='[danceability]' role='dimension' type='nominal' />
            <column caption='Energy' datatype='string' default-role='measure' default-type='quantitative' name='[energy]' role='dimension' type='nominal' />
