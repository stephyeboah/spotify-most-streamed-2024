    <dashboard enable-sort-zone-taborder='true' name='Dashboard 2'>
      <style />
      <size maxheight='860' maxwidth='1420' minheight='560' minwidth='1220' sizing-mode='range' />
      <datasources>
        <datasource caption='df2' name='federated.0v3lhgz1bxzq8u153cwbf189s6j7' />
      </datasources>
      <datasource-dependencies datasource='federated.0v3lhgz1bxzq8u153cwbf189s6j7'>
        <column datatype='string' name='[Track]' role='dimension' type='nominal' />
        <column-instance column='[Track]' derivation='None' name='[none:Track:nk]' pivot='key' type='nominal' />
      </datasource-dependencies>
      <zones>
        <zone h='100000' id='10' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98004' id='43' param='horz' type-v2='layout-flow' w='98874' x='563' y='998'>
            <zone h='98004' id='34' param='horz' type-v2='layout-flow' w='87606' x='563' y='998'>
              <zone h='98004' id='32' type-v2='layout-basic' w='87606' x='563' y='998'>
                <zone h='39524' id='9' name='Foglio 5' w='31697' x='29577' y='998'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='39524' id='11' name='Foglio 6' w='26895' x='61274' y='998'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='39524' id='13' name='Foglio 4' w='29014' x='563' y='998'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='26185' id='35' type-v2='text' w='87606' x='563' y='40522'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>This dashboard analyzes of track characteristics across different popularity categories (Low, Medium, High). The visualizations explore relationships between musical attributes such as danceability, acousticness, and energy to identify patterns that correlate with track popularity. The analysis helps identify optimal musical characteristics for creating engaging content.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>The analysis reveals that popular songs tend to have:</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>- </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'> moderate to high danceability,</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'> but there isn&apos;t a significant difference across popularity levels. This indicates that while danceability is important, it may not be the main factor influencing popularity.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>-  </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>acousticness is slightly higher in more popular songs</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>, while electronic elements dominate, some level of acoustic presence may contribute to higher popularity.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>- </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>energy levels decrease slightly as popularity increases</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>, indicating that excessively high-energy tracks may not be as widely favored. Instead, </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>moderately energetic songs</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'> dominate in popularity, likely because they strike a balance between intensity and listenability, making them more appealing to a broader audience.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='32295' id='40' type-v2='text' w='31057' x='57112' y='66707'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>The tempo (BPM) distribution shows that the most common BPM ranges among popular songs are </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>90 and 120 BPM</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>, followed by </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>100 BPM</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>. This suggests that mid-bpm songs are preferred among listeners, possibly because they offer a balance between rhythm and versatility in different music genres.</run>
                    <run>Æ&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
                <zone h='32295' id='41' name='Foglio 7' w='56549' x='563' y='66707'>
                  <zone-style>
