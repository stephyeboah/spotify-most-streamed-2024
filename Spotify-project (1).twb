              <zone h='98334' id='77' param='vert' type-v2='layout-flow' w='98874' x='563' y='833'>
                <zone fixed-size='280' h='40417' id='5' is-fixed='true' name='Foglio 1' w='66056' x='563' y='833'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
