                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                  </zone-style>
                </zone>
              </zone>
            </zone>
            <zone fixed-size='160' h='98004' id='42' is-fixed='true' param='vert' type-v2='layout-flow' w='11268' x='88169' y='998'>
              <zone h='98004' id='44' name='Foglio 7' param='[federated.0v3lhgz1bxzq8u153cwbf189s6j7].[none:Track:nk]' type-v2='filter' w='11268' x='88169' y='998'>
